{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #HeroBanner-{{ section.id }} {
    --pj-cream:  #FDF6EC;
    --pj-brown:  #4A2C0A;
    --pj-orange: #C8651B;
  }

  /* Slide height */
  #HeroBanner-{{ section.id }}.hero-banner--small  { --banner-height: 42rem; }
  #HeroBanner-{{ section.id }}.hero-banner--medium { --banner-height: 58rem; }
  #HeroBanner-{{ section.id }}.hero-banner--large  { --banner-height: 72rem; }

  #HeroBanner-{{ section.id }} .hero-banner__slide {
    position: relative;
    width: 100%;
    height: var(--banner-height, 58rem);
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Slider track */
  #HeroBanner-{{ section.id }} .hero-banner__track {
    display: flex;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  /* Images */
  #HeroBanner-{{ section.id }} .hero-banner__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  #HeroBanner-{{ section.id }} .hero-banner__media img,
  #HeroBanner-{{ section.id }} .hero-banner__media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #HeroBanner-{{ section.id }} .hero-banner__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(30, 12, 2, var(--overlay-opacity, 0.4));
  }

  /* Content overlay */
  #HeroBanner-{{ section.id }} .hero-banner__content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.4rem;
    text-align: center;
    z-index: 2;
  }
  #HeroBanner-{{ section.id }} .hero-banner__inner {
    max-width: 72rem;
  }
  #HeroBanner-{{ section.id }} .hero-banner__eyebrow {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pj-orange);
    margin-bottom: 1.2rem;
  }
  #HeroBanner-{{ section.id }} .hero-banner__heading {
    font-size: clamp(2.8rem, 5vw, 5.6rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--pj-cream);
    margin: 0 0 1.6rem;
  }
  #HeroBanner-{{ section.id }} .hero-banner__subtext {
    font-size: clamp(1.5rem, 2vw, 1.8rem);
    line-height: 1.6;
    color: var(--pj-cream);
    opacity: 0.88;
    margin: 0 0 2.8rem;
  }
  #HeroBanner-{{ section.id }} .hero-banner__cta {
    display: inline-block;
    padding: 1.4rem 3.2rem;
    background: var(--pj-orange);
    color: var(--pj-cream);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid var(--pj-orange);
    border-radius: 0.3rem;
    transition: background 0.25s, color 0.25s;
  }
  #HeroBanner-{{ section.id }} .hero-banner__cta:hover,
  #HeroBanner-{{ section.id }} .hero-banner__cta:focus-visible {
    background: transparent;
    color: var(--pj-cream);
  }
  #HeroBanner-{{ section.id }} .hero-banner__cta--outline {
    background: transparent;
    color: var(--pj-cream);
    border-color: var(--pj-cream);
  }
  #HeroBanner-{{ section.id }} .hero-banner__cta--outline:hover,
  #HeroBanner-{{ section.id }} .hero-banner__cta--outline:focus-visible {
    background: var(--pj-cream);
    color: var(--pj-brown);
  }

  /* Prev / Next arrows */
  #HeroBanner-{{ section.id }} .hero-banner__arrows {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.6rem;
  }
  #HeroBanner-{{ section.id }} .hero-banner__arrow {
    pointer-events: all;
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 50%;
    border: 2px solid rgba(253,246,236,0.5);
    background: rgba(74,44,10,0.4);
    color: var(--pj-cream);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    backdrop-filter: blur(4px);
  }
  #HeroBanner-{{ section.id }} .hero-banner__arrow:hover {
    background: var(--pj-orange);
    border-color: var(--pj-orange);
  }
  #HeroBanner-{{ section.id }} .hero-banner__arrow svg {
    width: 1.6rem;
    height: 1.6rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Dot navigation */
  #HeroBanner-{{ section.id }} .hero-banner__dots {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.8rem;
  }
  #HeroBanner-{{ section.id }} .hero-banner__dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    border: 2px solid var(--pj-cream);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }
  #HeroBanner-{{ section.id }} .hero-banner__dot.is-active,
  #HeroBanner-{{ section.id }} .hero-banner__dot:hover {
    background: var(--pj-orange);
    border-color: var(--pj-orange);
    transform: scale(1.3);
  }

  /* Mobile: text below image */
  @media screen and (max-width: 749px) {
    #HeroBanner-{{ section.id }}.hero-banner--text-below .hero-banner__slide {
      height: auto;
      display: flex;
      flex-direction: column;
    }
    #HeroBanner-{{ section.id }}.hero-banner--text-below .hero-banner__media {
      position: relative;
      height: 26rem;
    }
    #HeroBanner-{{ section.id }}.hero-banner--text-below .hero-banner__content {
      position: relative;
      inset: auto;
      background: var(--pj-brown);
      padding: 3.2rem 2rem;
    }
    #HeroBanner-{{ section.id }}.hero-banner--text-below .hero-banner__heading,
    #HeroBanner-{{ section.id }}.hero-banner--text-below .hero-banner__subtext {
      color: var(--pj-cream);
    }
    #HeroBanner-{{ section.id }}.hero-banner--text-below .hero-banner__arrows {
      top: 0;
      height: 26rem;
      align-items: center;
    }

    #HeroBanner-{{ section.id }}:not(.hero-banner--text-below) .hero-banner__slide {
      height: 56vw;
      min-height: 28rem;
    }
  }
{%- endstyle -%}

{%- liquid
  assign slide_height_class = 'hero-banner--' | append: section.settings.slide_height
  assign text_below_class = ''
  if section.settings.show_text_below_mobile
    assign text_below_class = ' hero-banner--text-below'
  endif
-%}

<div
  id="HeroBanner-{{ section.id }}"
  class="hero-banner {{ slide_height_class }}{{ text_below_class }}"
  style="position:relative; overflow:hidden; width:100%;"
  data-autoplay="{{ section.settings.auto_rotate }}"
  data-speed="{{ section.settings.change_slides_speed }}"
>
  <!-- Slide track -->
  <div class="hero-banner__track" id="HeroBannerTrack-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- assign overlay_opacity = block.settings.image_overlay_opacity | divided_by: 100.0 -%}
      <div
        class="hero-banner__slide"
        id="HeroBannerSlide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        aria-label="Slide {{ forloop.index }} of {{ forloop.length }}"
      >
        <!-- Image -->
        <div class="hero-banner__media" style="--overlay-opacity: {{ overlay_opacity }};">
          {%- if block.settings.image != blank -%}
            {%- liquid
              assign img_height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
              assign fetch_priority = 'auto'
              if forloop.first and section.index == 1
                assign fetch_priority = 'high'
              endif
            -%}
            {{
              block.settings.image
              | image_url: width: 3840
              | image_tag:
                height: img_height,
                sizes: '100vw',
                widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                loading: forloop.first | default: 'lazy',
                fetchpriority: fetch_priority
            }}
          {%- else -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                <img
                  src="https://upload.wikimedia.org/wikipedia/commons/c/ca/Filter_Kaapi.jpg"
                  alt="Traditional South Indian filter coffee in a tumbler — Paul John Caffeine"
                  loading="eager"
                  style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;"
                >
              {%- when 2 -%}
                <img
                  src="https://upload.wikimedia.org/wikipedia/commons/5/51/Filter_kaapi.JPG"
                  alt="Authentic South Indian filter kaapi — Paul John Caffeine"
                  loading="lazy"
                  style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;"
                >
              {%- when 3 -%}
                <img
                  src="https://upload.wikimedia.org/wikipedia/commons/1/10/GKN_Filter_Coffee_DSC_1038.JPG"
                  alt="South Indian filter coffee in steel davara tumbler — Paul John Caffeine"
                  loading="lazy"
                  style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;"
                >
              {%- else -%}
                <img
                  src="https://upload.wikimedia.org/wikipedia/commons/b/b0/Foaming_filter_coffee.jpg"
                  alt="Coffee beans — Paul John Caffeine"
                  loading="lazy"
                  style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;"
                >
            {%- endcase -%}
          {%- endif -%}
        </div>

        <!-- Overlay + content -->
        <div class="hero-banner__content" style="--overlay-opacity: {{ overlay_opacity }};">
          <div class="hero-banner__inner">
            {%- if block.settings.eyebrow != blank -%}
              <span class="hero-banner__eyebrow">{{ block.settings.eyebrow | escape }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="hero-banner__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.subtext != blank -%}
              <p class="hero-banner__subtext">{{ block.settings.subtext | escape }}</p>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a
                {% if block.settings.button_link != blank %}
                  href="{{ block.settings.button_link }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
                class="hero-banner__cta{% if block.settings.button_style_outline %} hero-banner__cta--outline{% endif %}"
              >
                {{- block.settings.button_label | escape -}}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <!-- Arrows (only when more than 1 slide) -->
  {%- if section.blocks.size > 1 -%}
    <div class="hero-banner__arrows" aria-hidden="true">
      <button
        type="button"
        class="hero-banner__arrow hero-banner__arrow--prev"
        data-direction="prev"
        aria-label="Previous slide"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button
        type="button"
        class="hero-banner__arrow hero-banner__arrow--next"
        data-direction="next"
        aria-label="Next slide"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
      </button>
    </div>

    <!-- Dot indicators -->
    <div class="hero-banner__dots" role="tablist" aria-label="Slide navigation">
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="hero-banner__dot{% if forloop.first %} is-active{% endif %}"
          role="tab"
          aria-label="Go to slide {{ forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          data-index="{{ forloop.index0 }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<script>
(function () {
  var section = document.getElementById('HeroBanner-{{ section.id }}');
  if (!section) return;

  var track    = section.querySelector('.hero-banner__track');
  var slides   = section.querySelectorAll('.hero-banner__slide');
  var dots     = section.querySelectorAll('.hero-banner__dot');
  var total    = slides.length;
  var current  = 0;
  var timer    = null;

  if (total <= 1) return;

  var autoplay  = section.dataset.autoplay === 'true';
  var speed     = (parseInt(section.dataset.speed, 10) || 5) * 1000;

  function goTo(index) {
    current = (index + total) % total;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    dots.forEach(function (d, i) {
      d.classList.toggle('is-active', i === current);
      d.setAttribute('aria-selected', i === current ? 'true' : 'false');
    });
  }

  /* Arrow clicks */
  section.querySelectorAll('.hero-banner__arrow').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var dir = btn.dataset.direction === 'prev' ? -1 : 1;
      goTo(current + dir);
      if (autoplay) resetTimer();
    });
  });

  /* Dot clicks */
  dots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      goTo(parseInt(dot.dataset.index, 10));
      if (autoplay) resetTimer();
    });
  });

  /* Touch / swipe */
  var touchStartX = 0;
  track.addEventListener('touchstart', function (e) {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  track.addEventListener('touchend', function (e) {
    var delta = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(delta) > 40) goTo(current + (delta > 0 ? 1 : -1));
    if (autoplay) resetTimer();
  }, { passive: true });

  /* Autoplay */
  function startTimer() {
    timer = setInterval(function () { goTo(current + 1); }, speed);
  }
  function resetTimer() {
    clearInterval(timer);
    startTimer();
  }

  if (autoplay) startTimer();

  /* Pause on hover/focus */
  section.addEventListener('mouseenter', function () { clearInterval(timer); });
  section.addEventListener('mouseleave',  function () { if (autoplay) startTimer(); });
  section.addEventListener('focusin',     function () { clearInterval(timer); });
  section.addEventListener('focusout',    function () { if (autoplay) startTimer(); });
})();
</script>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "slide_height",
      "label": "Slide height",
      "options": [
        { "value": "small",  "label": "Small (42rem)" },
        { "value": "medium", "label": "Medium (58rem)" },
        { "value": "large",  "label": "Large (72rem)" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "label": "Seconds per slide",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "checkbox",
      "id": "show_text_below_mobile",
      "label": "Show text below image on mobile",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "range",
          "id": "image_overlay_opacity",
          "label": "Image overlay opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 40
        },
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow label",
          "placeholder": "e.g. New Arrival"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Pure South Indian Coffee"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Freshly roasted. Thoughtfully blended. Delivered to your door."
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "button_style_outline",
          "label": "Outline style button",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Welcome to Paul John Caffeine",
            "heading": "The Taste of <em>South India</em>",
            "subtext": "Freshly roasted arabica & robusta blends, crafted for the discerning cup.",
            "button_label": "Shop Coffee",
            "image_overlay_opacity": 40
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Bestseller",
            "heading": "Filter Coffee <em>Done Right</em>",
            "subtext": "Our signature decoction blend — bold, aromatic, and full of character.",
            "button_label": "Explore Blends",
            "image_overlay_opacity": 40
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Subscribe & Save",
            "heading": "Never Run Out of <em>Great Coffee</em>",
            "subtext": "Set up a subscription and get 15% off every order, delivered on your schedule.",
            "button_label": "Subscribe Now",
            "image_overlay_opacity": 40
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Our Story",
            "heading": "Heritage in <em>Every Sip</em>",
            "subtext": "Three generations of coffee farming from the Coorg hills, now in your home.",
            "button_label": "Our Story",
            "image_overlay_opacity": 40
          }
        }
      ]
    }
  ]
}
{% endschema %}
