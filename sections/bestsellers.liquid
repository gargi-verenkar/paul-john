{%- style -%}
  .pj-bestsellers {
    background: var(--pj-cream);
    padding: var(--pj-section-padding-desktop) 2rem;
  }
  @media (max-width: 749px) {
    .pj-bestsellers { padding: var(--pj-section-padding-mobile) 2rem; }
  }
  .pj-bestsellers__heading {
    text-align: center;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pj-brown);
    margin: 0 0 4.4rem;
  }
  .pj-bestsellers__grid {
    max-width: 124rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 750px) {
    .pj-bestsellers__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 990px) {
    .pj-bestsellers__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .pj-product-card {
    background: #fff;
    border-radius: 0.4rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 16px rgba(74,44,10,0.07);
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .pj-product-card:hover {
    box-shadow: 0 8px 32px rgba(74,44,10,0.13);
    transform: translateY(-4px);
  }
  .pj-product-card__img-wrap {
    position: relative;
    width: 100%;
    padding-top: 100%;
    overflow: hidden;
    background: #f5ede0;
  }
  .pj-product-card__img-wrap a {
    position: absolute;
    inset: 0;
    display: block;
  }
  .pj-product-card__img-wrap img,
  .pj-product-card__img-wrap .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .pj-product-card:hover .pj-product-card__img-wrap img {
    transform: scale(1.05);
  }
  .pj-product-card__body {
    padding: 2rem 2.2rem 2.4rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .pj-product-card__subtitle {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pj-orange);
  }
  .pj-product-card__title {
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--pj-brown);
    text-decoration: none;
    line-height: 1.3;
  }
  .pj-product-card__title:hover { color: var(--pj-orange); }
  .pj-product-card__desc {
    font-size: 1.35rem;
    color: rgba(74,44,10,0.65);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }
  .pj-product-card__price {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--pj-brown);
    margin-top: 0.4rem;
  }
  .pj-product-card__atc {
    display: block;
    width: 100%;
    margin-top: 1.2rem;
    padding: 1.2rem;
    background: var(--pj-orange);
    color: var(--pj-cream);
    border: 2px solid var(--pj-orange);
    border-radius: var(--pj-btn-radius);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    cursor: pointer;
    transition: background 0.22s, color 0.22s;
    font-family: var(--pj-font);
  }
  .pj-product-card__atc:hover { background: var(--pj-brown); border-color: var(--pj-brown); }
  .pj-product-card__atc[disabled] { opacity: 0.5; cursor: not-allowed; }
{%- endstyle -%}

{%- liquid
  assign coll = collections[section.settings.collection]
  assign prods = coll.products
-%}

<div class="pj-bestsellers">
  {%- if section.settings.heading != blank -%}
    <h2 class="pj-bestsellers__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="pj-bestsellers__grid">
    {%- if prods != blank -%}
      {%- for product in prods limit: 3 -%}
        <article class="pj-product-card">
          <div class="pj-product-card__img-wrap">
            <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
              {%- if product.featured_image -%}
                {{
                  product.featured_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    widths: '400,600,800',
                    sizes: '(min-width:990px) 33vw,(min-width:750px) 50vw,100vw',
                    alt: product.featured_image.alt | escape
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
          </div>
          <div class="pj-product-card__body">
            <span class="pj-product-card__subtitle">Crafted by Paul John Caffeine</span>
            <a href="{{ product.url }}" class="pj-product-card__title">{{ product.title | escape }}</a>
            {%- if product.description != blank -%}
              <p class="pj-product-card__desc">{{ product.description | strip_html | truncate: 90 }}</p>
            {%- endif -%}
            <div class="pj-product-card__price">
              {%- if product.price_varies -%}From {{ product.price_min | money }}{%- else -%}{{ product.price | money }}{%- endif -%}
            </div>
            <form action="{{ routes.cart_add_url }}" method="post">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="pj-product-card__atc" {%- unless product.available %} disabled{%- endunless -%}>
                {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
              </button>
            </form>
          </div>
        </article>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..3) -%}
        <article class="pj-product-card">
          <div class="pj-product-card__img-wrap">
            <a href="#">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</a>
          </div>
          <div class="pj-product-card__body">
            <span class="pj-product-card__subtitle">Crafted by Paul John Caffeine</span>
            <span class="pj-product-card__title">Sample Coffee Blend {{ i }}</span>
            <p class="pj-product-card__desc">Rich South Indian coffee, freshly roasted in the USA.</p>
            <div class="pj-product-card__price">$18.00</div>
            <button class="pj-product-card__atc" disabled>Add to Cart</button>
          </div>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Bestsellers",
  "tag": "section",
  "class": "section-bestsellers",
  "disabled_on": { "groups": ["header","footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP OUR BESTSELLERS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [{ "name": "Bestsellers" }]
}
{% endschema %}
