{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .pj-footer {
    background: var(--pj-brown);
    font-family: var(--pj-font);
  }

  /* ---- Main grid ---- */
  .pj-footer__main {
    padding: 6rem 2rem 5rem;
    max-width: 140rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 750px)  { .pj-footer__main { grid-template-columns: repeat(2,1fr); } }
  @media (min-width: 990px)  { .pj-footer__main { grid-template-columns: 1.8fr 1fr 1fr 1.6fr; gap: 5rem; } }

  /* Column headings */
  .pj-footer__col-title {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--pj-orange);
    margin: 0 0 2rem;
  }

  /* Brand col */
  .pj-footer__brand-name {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pj-cream);
    margin: 0 0 0.6rem;
    line-height: 1.1;
  }
  .pj-footer__brand-tag {
    font-size: 1.25rem;
    color: rgba(253,246,236,0.55);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 2.4rem;
  }
  .pj-footer__brand-desc {
    font-size: 1.4rem;
    color: rgba(253,246,236,0.65);
    line-height: 1.7;
    margin: 0;
  }

  /* Nav links */
  .pj-footer__nav {
    list-style: none;
    padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 1rem;
  }
  .pj-footer__nav a {
    font-size: 1.4rem;
    color: rgba(253,246,236,0.75);
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.2s;
  }
  .pj-footer__nav a:hover { color: var(--pj-orange); }

  /* Contact col */
  .pj-footer__contact {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 1.4rem;
  }
  .pj-footer__contact-item {
    display: flex; align-items: flex-start; gap: 1rem;
    font-size: 1.4rem;
    color: rgba(253,246,236,0.75);
    line-height: 1.55;
  }
  .pj-footer__contact-item svg {
    width: 1.7rem; height: 1.7rem; flex-shrink: 0;
    fill: none; stroke: var(--pj-orange);
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    margin-top: 0.15rem;
  }
  .pj-footer__contact-item a {
    color: inherit; text-decoration: none; transition: color 0.2s;
  }
  .pj-footer__contact-item a:hover { color: var(--pj-orange); }
  .pj-footer__affiliate {
    display: inline-block;
    margin-top: 1.6rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pj-orange);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.2rem;
    transition: opacity 0.2s;
  }
  .pj-footer__affiliate:hover { opacity: 0.72; }

  /* Divider */
  .pj-footer__hr {
    border: none;
    border-top: 1px solid rgba(253,246,236,0.1);
    margin: 0;
  }

  /* Social row */
  .pj-footer__social {
    padding: 2.8rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.6rem;
    flex-wrap: wrap;
  }
  .pj-footer__social a {
    display: flex; align-items: center; justify-content: center;
    width: 4rem; height: 4rem;
    border-radius: 50%;
    border: 1px solid rgba(253,246,236,0.2);
    color: rgba(253,246,236,0.7);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .pj-footer__social a:hover {
    color: var(--pj-cream);
    background: var(--pj-orange);
    border-color: var(--pj-orange);
  }
  .pj-footer__social svg { width: 1.8rem; height: 1.8rem; fill: currentColor; }

  /* Payment row */
  .pj-footer__payment {
    padding: 1.4rem 2rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid rgba(253,246,236,0.08);
  }
  .pj-footer__payment-label {
    font-size: 1.15rem;
    color: rgba(253,246,236,0.45);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-right: 0.4rem;
  }
  .pj-footer__payment .icon--full-color { height: 2.4rem; width: auto; }

  /* Copyright */
  .pj-footer__copyright {
    background: var(--pj-brown-dark, #2A1505);
    padding: 1.6rem 2rem;
    text-align: center;
  }
  .pj-footer__copyright p {
    margin: 0;
    font-size: 1.15rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(253,246,236,0.4);
  }
{%- endstyle -%}

{%- liquid
  assign has_ig  = false
  assign has_fb  = false
  assign has_tk  = false
  assign has_tw  = false
  assign has_yt  = false
  assign has_pin = false
  if settings.social_instagram_link != blank
    assign has_ig = true
  endif
  if settings.social_facebook_link != blank
    assign has_fb = true
  endif
  if settings.social_tiktok_link != blank
    assign has_tk = true
  endif
  if settings.social_twitter_link != blank
    assign has_tw = true
  endif
  if settings.social_youtube_link != blank
    assign has_yt = true
  endif
  if settings.social_pinterest_link != blank
    assign has_pin = true
  endif
-%}

<footer class="pj-footer">

  <!-- Main columns -->
  <div class="pj-footer__main">

    <!-- Brand column -->
    <div>
      <p class="pj-footer__brand-name">{{ section.settings.brand_name | default: shop.name }}</p>
      <p class="pj-footer__brand-tag">{{ section.settings.brand_tagline | escape }}</p>
      <p class="pj-footer__brand-desc">{{ section.settings.brand_desc | escape }}</p>
    </div>

    <!-- Link columns from blocks -->
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h3 class="pj-footer__col-title">{{ block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul class="pj-footer__nav">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    <!-- Connect column -->
    <div>
      <h3 class="pj-footer__col-title">Connect With Us</h3>
      <ul class="pj-footer__contact">
        {%- if section.settings.phone != blank -%}
          <li class="pj-footer__contact-item">
            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.99 5.99l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone | escape }}</a>
          </li>
        {%- endif -%}
        {%- if section.settings.email != blank -%}
          <li class="pj-footer__contact-item">
            <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a>
          </li>
        {%- endif -%}
        {%- if section.settings.address != blank -%}
          <li class="pj-footer__contact-item">
            <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <address style="font-style:normal">{{ section.settings.address | escape | newline_to_br }}</address>
          </li>
        {%- endif -%}
      </ul>
      {%- if section.settings.affiliate_link != blank -%}
        <a href="{{ section.settings.affiliate_link }}" class="pj-footer__affiliate" target="_blank" rel="noopener">
          {{ section.settings.affiliate_label | default: 'Join Our Affiliate Program' | escape }}
        </a>
      {%- endif -%}
    </div>

  </div>

  <hr class="pj-footer__hr">

  <!-- Social icons -->
  {%- if has_ig or has_fb or has_tk or has_tw or has_yt or has_pin -%}
    <div class="pj-footer__social">
      {%- if has_ig -%}
        <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
      {%- endif -%}
      {%- if has_fb -%}
        <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      {%- endif -%}
      {%- if has_tk -%}
        <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">
          <svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.86 4.86 0 0 1-1.02-.07z"/></svg>
        </a>
      {%- endif -%}
      {%- if has_tw -%}
        <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" aria-label="Twitter / X">
          <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      {%- endif -%}
      {%- if has_yt -%}
        <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20.06 12 20.06 12 20.06s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" style="fill:var(--pj-brown)"/></svg>
        </a>
      {%- endif -%}
      {%- if has_pin -%}
        <a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener" aria-label="Pinterest">
          <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- Payment icons -->
  {%- if shop.enabled_payment_types.size > 0 -%}
    <div class="pj-footer__payment">
      <span class="pj-footer__payment-label">We Accept</span>
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Copyright -->
  <div class="pj-footer__copyright">
    <p>{{ section.settings.brand_name | default: shop.name | upcase }} &copy; {{ 'now' | date: '%Y' }} ALL RIGHTS RESERVED</p>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer",
  "enabled_on": { "groups": ["footer"] },
  "settings": [
    {
      "type": "header", "content": "Brand"
    },
    { "type": "text",    "id": "brand_name",    "label": "Brand name",        "default": "Paul John Caffeine" },
    { "type": "text",    "id": "brand_tagline", "label": "Tagline",           "default": "Premium South Indian Coffee" },
    { "type": "text",    "id": "brand_desc",    "label": "Brand description", "default": "Ethically sourced, freshly roasted. Delivered to your door." },
    {
      "type": "header", "content": "Contact"
    },
    { "type": "text",     "id": "phone",           "label": "Phone",            "default": "+1 813-808-7639" },
    { "type": "text",     "id": "email",           "label": "Email",            "default": "hello@pauljohncaffeine.com" },
    { "type": "textarea", "id": "address",         "label": "Address",          "default": "5010 North Coolidge Ave, Unit 2\nTampa, Florida 33614" },
    { "type": "url",      "id": "affiliate_link",  "label": "Affiliate link" },
    { "type": "text",     "id": "affiliate_label", "label": "Affiliate link text", "default": "Join Our Affiliate Program" }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation Column",
      "settings": [
        { "type": "text",      "id": "heading", "label": "Column heading", "default": "Links" },
        { "type": "link_list", "id": "menu",    "label": "Menu",           "default": "footer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "LINK",             "menu": "footer" } },
        { "type": "link_list", "settings": { "heading": "Coffee Varieties" } }
      ]
    }
  ]
}
{% endschema %}
