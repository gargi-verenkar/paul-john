{%- style -%}
  .pj-contact__hero {
    position: relative; height: 38rem; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .pj-contact__hero img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  }
  .pj-contact__hero-overlay { position: absolute; inset: 0; background: rgba(30,12,2,0.5); }
  .pj-contact__hero-content { position: relative; z-index: 2; text-align: center; color: #ffffff; }
  .pj-contact__breadcrumb {
    font-size: 1.2rem; letter-spacing: 0.1em; text-transform: uppercase;
    opacity: 0.8; margin-bottom: 1rem; font-family: var(--pj-font);
    color: #ffffff !important;
  }
  .pj-contact__hero-title {
    font-size: clamp(2.8rem, 5vw, 5rem); font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase; margin: 0; font-family: var(--pj-font);
    color: #ffffff !important;
    text-shadow: 0 2px 12px rgba(0,0,0,0.35);
  }

  .pj-contact__body {
    max-width: 110rem; margin: 0 auto; padding: 6rem 2rem;
    display: grid; grid-template-columns: 1fr 30rem; gap: 6rem;
  }
  @media (max-width: 799px) { .pj-contact__body { grid-template-columns: 1fr; gap: 4rem; } }

  /* Form card */
  .pj-contact__form-card {
    background: #D4B896; border-radius: 0.4rem; padding: 3.2rem;
  }
  .pj-contact__form-card h2 {
    font-size: 1.8rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--pj-brown);
    margin: 0 0 0.6rem; font-family: var(--pj-font);
  }
  .pj-contact__form-card p {
    font-size: 1.35rem; color: rgba(74,44,10,0.75);
    margin: 0 0 2.4rem; font-family: var(--pj-font);
  }
  .pj-contact__row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-bottom: 1.2rem;
  }
  @media (max-width: 500px) { .pj-contact__row { grid-template-columns: 1fr; } }
  .pj-contact__field {
    width: 100%; padding: 1.1rem 1.4rem;
    border: 1px solid rgba(74,44,10,0.2); border-radius: 0.3rem;
    background: rgba(253,246,236,0.7); font-size: 1.35rem;
    color: var(--pj-brown); font-family: var(--pj-font); box-sizing: border-box;
    outline: none; transition: border-color 0.2s;
  }
  .pj-contact__field:focus { border-color: var(--pj-orange); }
  textarea.pj-contact__field { min-height: 12rem; resize: vertical; }
  .pj-contact__submit {
    width: 100%; padding: 1.3rem; margin-top: 1.6rem;
    background: var(--pj-brown); color: var(--pj-cream);
    font-size: 1.35rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; border: none; border-radius: 0.3rem;
    cursor: pointer; font-family: var(--pj-font); transition: background 0.2s;
  }
  .pj-contact__submit:hover { background: var(--pj-orange); }

  /* Sidebar */
  .pj-contact__sidebar {}
  .pj-contact__info-block { margin-bottom: 2.4rem; padding-bottom: 2.4rem; border-bottom: 1px solid rgba(74,44,10,0.12); }
  .pj-contact__info-block:last-child { border-bottom: none; }
  .pj-contact__info-label {
    font-size: 1.1rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--pj-brown);
    margin: 0 0 0.6rem; font-family: var(--pj-font);
  }
  .pj-contact__info-text {
    font-size: 1.35rem; color: rgba(74,44,10,0.75); line-height: 1.6;
    margin: 0 0 0.4rem; font-family: var(--pj-font);
  }
  .pj-contact__info-link {
    display: flex; align-items: center; gap: 0.6rem;
    font-size: 1.35rem; color: var(--pj-brown); text-decoration: none;
    font-family: var(--pj-font);
  }
  .pj-contact__info-link:hover { color: var(--pj-orange); }
  .pj-contact__info-link svg {
    width: 1.5rem; height: 1.5rem; flex-shrink: 0;
    fill: none; stroke: currentColor; stroke-width: 1.8;
    stroke-linecap: round; stroke-linejoin: round;
  }

  /* FAQ */
  .pj-contact__faq { max-width: 110rem; margin: 0 auto; padding: 2rem 2rem 6rem; }
  .pj-contact__faq h2 {
    font-size: 2rem; font-weight: 700; color: var(--pj-brown);
    margin: 0 0 2rem; font-family: var(--pj-font);
  }
  .pj-cfaq-item { border-top: 1px solid rgba(74,44,10,0.15); }
  .pj-cfaq-item:last-child { border-bottom: 1px solid rgba(74,44,10,0.15); }
  .pj-cfaq-trigger {
    width: 100%; background: none; border: none;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.6rem 0; cursor: pointer;
    font-size: 1.45rem; font-weight: 600; color: var(--pj-brown);
    text-align: left; font-family: var(--pj-font); gap: 1.6rem;
  }
  .pj-cfaq-trigger svg {
    width: 1.6rem; height: 1.6rem; flex-shrink: 0;
    fill: none; stroke: var(--pj-orange); stroke-width: 2.5;
    stroke-linecap: round; stroke-linejoin: round; transition: transform 0.3s;
  }
  .pj-cfaq-item.is-open .pj-cfaq-trigger svg { transform: rotate(45deg); }
  .pj-cfaq-answer { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
  .pj-cfaq-item.is-open .pj-cfaq-answer { max-height: 30rem; }
  .pj-cfaq-answer p {
    font-size: 1.4rem; color: rgba(74,44,10,0.75);
    line-height: 1.7; padding: 0 0 1.6rem; margin: 0; font-family: var(--pj-font);
  }
{%- endstyle -%}

<!-- Hero -->
<div class="pj-contact__hero">
  {%- if section.settings.hero_image != blank -%}
    {{ section.settings.hero_image | image_url: width: 1600 | image_tag: loading: 'eager', alt: 'Contact Us' }}
  {%- else -%}
    <!-- PLACEHOLDER: Replace with contact page hero image in Theme Customizer -->
    <img
      src="https://static.vecteezy.com/system/resources/previews/013/754/137/non_2x/south-indian-filter-coffee-served-in-a-traditional-brass-or-stainless-steel-cup-free-photo.jpg"
      alt="Coffee cup — Contact Us"
      loading="eager"
    >
  {%- endif -%}
  <div class="pj-contact__hero-overlay"></div>
  <div class="pj-contact__hero-content">
    <p class="pj-contact__breadcrumb">Home / Contact Us</p>
    <h1 class="pj-contact__hero-title">Contact Us</h1>
  </div>
</div>

<!-- Body -->
<div class="pj-contact__body">
  <!-- Form -->
  <div class="pj-contact__form-card">
    <h2>Fill This Form</h2>
    <p>We love hearing from our customers. All communication is handled by our team on site, and never outsourced.</p>
    {%- form 'contact', id: 'pjContactForm' -%}
      {%- if form.posted_successfully? -%}
        <p style="color:#1A7A4A;font-weight:600;font-family:var(--pj-font);">✓ Thank you! Your message has been sent.</p>
      {%- else -%}
        <div style="margin-bottom:1.2rem;">
          <input class="pj-contact__field" type="text" name="contact[name]" placeholder="Name *" required>
        </div>
        <div class="pj-contact__row">
          <input class="pj-contact__field" type="email" name="contact[email]" placeholder="Email *" required>
          <input class="pj-contact__field" type="tel"   name="contact[phone]" placeholder="Phone">
        </div>
        <textarea class="pj-contact__field" name="contact[body]" placeholder="Message *" required></textarea>
        <button class="pj-contact__submit" type="submit">Send</button>
      {%- endif -%}
    {%- endform -%}
  </div>

  <!-- Sidebar -->
  <div class="pj-contact__sidebar">
    <div class="pj-contact__info-block">
      <p class="pj-contact__info-label">Call Us</p>
      <p class="pj-contact__info-text">Call us on below number.<br>Our timings are 9:00 AM – 5:00 PM</p>
      <a href="tel:+18138087639" class="pj-contact__info-link">
        <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        +1 813-808-7639
      </a>
    </div>
    <div class="pj-contact__info-block">
      <p class="pj-contact__info-label">Email Us</p>
      <p class="pj-contact__info-text">Email us &amp; we will reply within 2–3 days.</p>
      <a href="mailto:info@pauljohncaffeine.com" class="pj-contact__info-link">
        <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        info@pauljohncaffeine.com
      </a>
    </div>
    <div class="pj-contact__info-block">
      <a href="#" class="pj-contact__info-link">
        <svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        Join our affiliate program
      </a>
    </div>
  </div>
</div>

<!-- FAQ -->
<div class="pj-contact__faq">
  <h2>F.A.Q.</h2>
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq' -%}
      <div class="pj-cfaq-item" {{ block.shopify_attributes }}>
        <button class="pj-cfaq-trigger" type="button">
          {{ block.settings.question | escape }}
          <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <div class="pj-cfaq-answer"><p>{{ block.settings.answer }}</p></div>
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="pj-cfaq-item">
      <button class="pj-cfaq-trigger" type="button">
        How do I track my order?
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <div class="pj-cfaq-answer"><p>To track your order, check your email for the shipping confirmation. We provide a tracking ID and link, allowing you to monitor your coffee's journey from our roastery to your doorstep.</p></div>
    </div>
    <div class="pj-cfaq-item">
      <button class="pj-cfaq-trigger" type="button">
        How long does an order take to ship?
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <div class="pj-cfaq-answer"><p>Orders typically ship within 1–2 business days after roasting. Standard delivery takes 3–5 business days depending on your location within the USA.</p></div>
    </div>
    <div class="pj-cfaq-item">
      <button class="pj-cfaq-trigger" type="button">
        What do I do if the order I received is wrong?
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <div class="pj-cfaq-answer"><p>We're sorry to hear that! Please contact us at info@pauljohncaffeine.com within 7 days of delivery with your order number and a photo of the item received. We'll make it right immediately.</p></div>
    </div>
    <div class="pj-cfaq-item">
      <button class="pj-cfaq-trigger" type="button">
        How can I return my order?
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <div class="pj-cfaq-answer"><p>We accept returns on non-coffee items within 30 days of purchase. For food/perishable items like coffee, we offer replacements if the product is damaged or defective. Contact us to initiate a return.</p></div>
    </div>
  {%- endfor -%}
</div>

<script>
document.querySelectorAll('.pj-cfaq-trigger').forEach(function(btn){
  btn.addEventListener('click', function(){
    var item = btn.closest('.pj-cfaq-item');
    var open = item.classList.contains('is-open');
    document.querySelectorAll('.pj-cfaq-item').forEach(function(i){ i.classList.remove('is-open'); });
    if(!open) item.classList.add('is-open');
  });
});
</script>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero background image" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer",   "label": "Answer" }
      ]
    }
  ],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
