{%- style -%}
  :root { --pj-cream:#FDF6EC; --pj-brown:#4A2C0A; --pj-orange:#C8651B; --pj-font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; }

  .pj-col-hero { position:relative; height:42rem; overflow:hidden; display:flex; align-items:center; justify-content:center; }
  .pj-col-hero__img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block; }
  .pj-col-hero__overlay { position:absolute; inset:0; background:rgba(20,8,0,0.52); }
  .pj-col-hero__content { position:relative; z-index:2; text-align:center; padding:2rem; }
  .pj-col-hero__breadcrumb { font-size:1.2rem; letter-spacing:0.12em; text-transform:uppercase; color:#ffffff !important; opacity:0.8; margin:0 0 1rem; font-family:var(--pj-font); }
  .pj-col-hero__title { font-size:clamp(2.8rem,5vw,5.2rem); font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#ffffff !important; margin:0 0 0.8rem; text-shadow:0 2px 16px rgba(0,0,0,0.4); font-family:var(--pj-font); }
  .pj-col-hero__sub { font-size:1.6rem; color:rgba(255,255,255,0.85); font-family:var(--pj-font); margin:0; font-style:italic; }

  .pj-collection__toolbar { max-width:140rem; margin:0 auto; padding:2rem 2rem 1rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1.2rem; }
  .pj-collection__count { font-size:1.4rem; color:rgba(74,44,10,0.65); font-family:var(--pj-font); }
  .pj-collection__sort { padding:0.8rem 1.4rem; border:1px solid rgba(74,44,10,0.25); border-radius:0.2rem; background:var(--pj-cream); font-size:1.35rem; color:var(--pj-brown); font-family:var(--pj-font); cursor:pointer; min-width:18rem; }

  .pj-collection__grid { max-width:140rem; margin:0 auto; padding:1.6rem 2rem 6rem; display:grid; grid-template-columns:repeat(3,1fr); gap:3.2rem; }
  @media(max-width:749px){ .pj-collection__grid{ grid-template-columns:repeat(2,1fr); gap:1.6rem; } }
  @media(max-width:480px){ .pj-collection__grid{ grid-template-columns:1fr; } }

  .pj-product-card { display:flex; flex-direction:column; background:var(--pj-cream); position:relative; }
  .pj-product-card__badge { position:absolute; top:1rem; left:1rem; background:var(--pj-orange); color:var(--pj-cream); font-size:1.1rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; padding:0.3rem 0.8rem; border-radius:0.2rem; z-index:2; font-family:var(--pj-font); }
  .pj-product-card__badge--oos { background:#888; }
  .pj-product-card__img-wrap { position:relative; overflow:hidden; aspect-ratio:1/1; display:block; }
  .pj-product-card__img-wrap img { width:100%; height:100%; object-fit:cover; transition:transform 0.4s; display:block; }
  .pj-product-card:hover .pj-product-card__img-wrap img { transform:scale(1.04); }
  .pj-product-card__body { padding:1.6rem 0; display:flex; flex-direction:column; gap:0.4rem; flex:1; }
  .pj-product-card__title { font-size:1.35rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--pj-brown); text-decoration:none; line-height:1.3; font-family:var(--pj-font); }
  .pj-product-card__title:hover { color:var(--pj-orange); }
  .pj-product-card__price { font-size:1.5rem; font-weight:700; color:var(--pj-brown); font-family:var(--pj-font); }
  .pj-product-card__price s { font-weight:400; color:rgba(74,44,10,0.5); margin-left:0.6rem; font-size:1.3rem; }
  .pj-product-card__btn { display:block; width:100%; padding:1.1rem; margin-top:1rem; background:var(--pj-brown); color:var(--pj-cream); font-size:1.25rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; text-align:center; text-decoration:none; border:none; border-radius:0.2rem; cursor:pointer; font-family:var(--pj-font); transition:background 0.2s; }
  .pj-product-card__btn:hover { background:var(--pj-orange); }
  .pj-product-card__btn--oos { background:#aaa; cursor:not-allowed; }

  .pj-collection__badges { background:#C4A882; padding:4rem 2rem; }
  .pj-collection__badges-inner { max-width:110rem; margin:0 auto; display:flex; align-items:center; justify-content:center; gap:3.2rem; flex-wrap:wrap; }
  .pj-cbadge { display:flex; flex-direction:column; align-items:center; gap:1rem; text-align:center; max-width:13rem; }
  .pj-cbadge__icon { width:6.4rem; height:6.4rem; border-radius:50%; border:1.5px solid rgba(74,44,10,0.45); display:flex; align-items:center; justify-content:center; }
  .pj-cbadge__icon svg { width:2.8rem; height:2.8rem; fill:none; stroke:var(--pj-brown); stroke-width:1.4; }
  .pj-cbadge__label { font-size:1.05rem; font-weight:700; letter-spacing:0.09em; text-transform:uppercase; color:var(--pj-brown); line-height:1.4; font-family:var(--pj-font); }

  .pj-collection__faq { max-width:104rem; margin:0 auto; padding:6rem 2rem; }
  .pj-collection__faq h2 { font-size:2rem; font-weight:700; color:var(--pj-brown); margin:0 0 2rem; font-family:var(--pj-font); }
  .pj-cfaq-item { border-top:1px solid rgba(74,44,10,0.15); }
  .pj-cfaq-item:last-child { border-bottom:1px solid rgba(74,44,10,0.15); }
  .pj-cfaq-trigger { width:100%; background:none; border:none; display:flex; align-items:center; justify-content:space-between; padding:1.6rem 0; cursor:pointer; font-size:1.45rem; font-weight:600; color:var(--pj-brown); text-align:left; font-family:var(--pj-font); gap:1.6rem; }
  .pj-cfaq-trigger svg { width:1.6rem; height:1.6rem; flex-shrink:0; fill:none; stroke:var(--pj-orange); stroke-width:2.5; stroke-linecap:round; stroke-linejoin:round; transition:transform 0.3s; }
  .pj-cfaq-item.is-open .pj-cfaq-trigger svg { transform:rotate(45deg); }
  .pj-cfaq-answer { max-height:0; overflow:hidden; transition:max-height 0.35s ease; }
  .pj-cfaq-item.is-open .pj-cfaq-answer { max-height:40rem; }
  .pj-cfaq-answer p { font-size:1.4rem; color:rgba(74,44,10,0.75); line-height:1.7; padding:0 0 1.6rem; margin:0; font-family:var(--pj-font); }
{%- endstyle -%}

{%- assign sixty_days_ago = 'now' | date: '%s' | minus: 5184000 | date: '%Y-%m-%dT%H:%M:%SZ' -%}

{%- assign hero_img = 'https://media.istockphoto.com/id/1426308030/photo/south-indian-filter-coffee-served-in-a-traditional-tumbler-or-cup-over-roasted-raw-beans.jpg?s=612x612&w=0&k=20&c=ELVrPPs4-9dXI6T9rrusrYQJ9op2IZg0vylfgbRUz_Q=' -%}
{%- assign hero_sub = 'Sourced from the hills of South India, roasted fresh in the USA' -%}
{%- case collection.handle -%}
  {%- when 'coffee' -%}
    {%- assign hero_img = 'https://media.istockphoto.com/id/1426308030/photo/south-indian-filter-coffee-served-in-a-traditional-tumbler-or-cup-over-roasted-raw-beans.jpg?s=612x612&w=0&k=20&c=ELVrPPs4-9dXI6T9rrusrYQJ9op2IZg0vylfgbRUz_Q=' -%}
    {%- assign hero_sub = 'Authentic South Indian filter coffee & premium blends' -%}
  {%- when 'drinkware' -%}
    {%- assign hero_img = 'https://static.vecteezy.com/system/resources/previews/013/754/137/non_2x/south-indian-filter-coffee-served-in-a-traditional-brass-or-stainless-steel-cup-free-photo.jpg' -%}
    {%- assign hero_sub = 'Elegant cups, tumblers & sets for every coffee ritual' -%}
  {%- when 'brewers' -%}
    {%- assign hero_img = 'https://www.yummytummyaarthi.com/wp-content/uploads/2012/03/1-9.jpeg' -%}
    {%- assign hero_sub = 'Brass filter sets, French presses & pour-over carafes' -%}
  {%- when 'gifting' -%}
    {%- assign hero_img = 'https://oldmadrasmarket.com/cdn/shop/files/AdobeStock_482039247.jpg?v=1749288088&width=1946' -%}
    {%- assign hero_sub = 'Thoughtfully curated coffee gift sets for every occasion' -%}
  {%- when 'bestsellers' -%}
    {%- assign hero_img = 'https://media.istockphoto.com/id/1426308030/photo/south-indian-filter-coffee-served-in-a-traditional-tumbler-or-cup-over-roasted-raw-beans.jpg?s=612x612&w=0&k=20&c=ELVrPPs4-9dXI6T9rrusrYQJ9op2IZg0vylfgbRUz_Q=' -%}
    {%- assign hero_sub = 'Our most-loved blends, loved by thousands of coffee drinkers' -%}
{%- endcase -%}

<div class="pj-col-hero">
  <img class="pj-col-hero__img" src="{{ hero_img }}" alt="{{ collection.title }} — Paul John Caffeine" loading="eager">
  <div class="pj-col-hero__overlay"></div>
  <div class="pj-col-hero__content">
    <p class="pj-col-hero__breadcrumb">Home / {{ collection.title }}</p>
    <h1 class="pj-col-hero__title">{{ collection.title }}</h1>
    <p class="pj-col-hero__sub">{{ hero_sub }}</p>
  </div>
</div>

<div class="pj-collection__toolbar">
  <p class="pj-collection__count">Showing {{ collection.products_count }} result{% if collection.products_count != 1 %}s{% endif %}</p>
  <select class="pj-collection__sort" id="pjSort" aria-label="Sort by">
    {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
    {%- for option in collection.sort_options -%}
      <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
    {%- endfor -%}
  </select>
</div>

<div class="pj-collection__grid">
  {%- if collection.products_count > 0 -%}
    {%- for product in collection.products -%}
      <div class="pj-product-card">
        {%- if product.available == false -%}
          <span class="pj-product-card__badge pj-product-card__badge--oos">Out of Stock</span>
        {%- elsif product.created_at > sixty_days_ago -%}
          <span class="pj-product-card__badge">New Product!</span>
        {%- endif -%}
        <a href="{{ product.url }}" class="pj-product-card__img-wrap">
          {%- if product.featured_image != blank -%}
            {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.featured_image.alt | default: product.title, widths: '300, 450, 600' }}
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1459755486867-b55449bb39ff?w=600&q=85&auto=format&fit=crop" alt="{{ product.title }}" loading="lazy">
          {%- endif -%}
        </a>
        <div class="pj-product-card__body">
          <a href="{{ product.url }}" class="pj-product-card__title">{{ product.title }}</a>
          <div class="pj-product-card__price">
            {{ product.price | money }}
            {%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}
          </div>
          {%- if product.available -%}
            {%- if product.variants.size == 1 -%}
              <button class="pj-product-card__btn" type="button" onclick="fetch('/cart/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:{{ product.variants.first.id }},quantity:1})}).then(()=>window.location='/cart')">Add to Cart</button>
            {%- else -%}
              <a href="{{ product.url }}" class="pj-product-card__btn">Select Options</a>
            {%- endif -%}
          {%- else -%}
            <button class="pj-product-card__btn pj-product-card__btn--oos" disabled>Out of Stock</button>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  {%- else -%}
    <div class="pj-collection__empty">
      <p>No products found in this collection yet. Check back soon!</p>
    </div>
  {%- endif -%}
</div>

<div class="pj-collection__badges">
  <div class="pj-collection__badges-inner">
    <div class="pj-cbadge"><div class="pj-cbadge__icon"><svg viewBox="0 0 24 24"><path d="M12 2l3 7h7l-6 4.5 2.3 7L12 17l-6.3 3.5L8 13.5 2 9h7z"/></svg></div><span class="pj-cbadge__label">Minority Women Owned Certified</span></div>
    <div class="pj-cbadge"><div class="pj-cbadge__icon"><svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.18"/><path d="M3.82 19.18C3.4 19.9 3 20.47 3 21h9c0-5-2.5-8-9-12"/><path d="M21 21c0-5.33-3-9.33-8-11"/></svg></div><span class="pj-cbadge__label">Handpicked &amp; Shade Grown</span></div>
    <div class="pj-cbadge"><div class="pj-cbadge__icon"><svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div><span class="pj-cbadge__label">Kosher Certified</span></div>
    <div class="pj-cbadge"><div class="pj-cbadge__icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4-4-1.79-4-4z"/></svg></div><span class="pj-cbadge__label">Premium Indian Grown Beans</span></div>
    <div class="pj-cbadge"><div class="pj-cbadge__icon"><svg viewBox="0 0 24 24"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg></div><span class="pj-cbadge__label">Freshly Roasted In The USA</span></div>
  </div>
</div>

{%- if section.blocks.size > 0 -%}
<div class="pj-collection__faq">
  <h2>F.A.Q.</h2>
  {%- for block in section.blocks -%}
    {%- if block.type == 'faq' -%}
      <div class="pj-cfaq-item" {{ block.shopify_attributes }}>
        <button class="pj-cfaq-trigger" type="button">
          {{ block.settings.question | escape }}
          <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <div class="pj-cfaq-answer"><p>{{ block.settings.answer }}</p></div>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>
{%- endif -%}

<script>
var sortSel=document.getElementById('pjSort');
if(sortSel)sortSel.addEventListener('change',function(){var u=new URL(window.location.href);u.searchParams.set('sort_by',this.value);window.location=u.toString();});
document.querySelectorAll('.pj-cfaq-trigger').forEach(function(b){b.addEventListener('click',function(){var i=b.closest('.pj-cfaq-item'),o=i.classList.contains('is-open');document.querySelectorAll('.pj-cfaq-item').forEach(function(x){x.classList.remove('is-open');});if(!o)i.classList.add('is-open');});});
</script>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Page heading", "default": "Explore the World of Paul John Caffeine" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer",   "label": "Answer"   }
      ]
    }
  ],
  "presets": [{ "name": "Collection Grid" }]
}
{% endschema %}
