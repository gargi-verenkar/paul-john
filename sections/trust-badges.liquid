{%- style -%}
  .pj-trust-badges {
    background: var(--pj-cream);
    padding: 3.2rem 2rem;
    border-top: 1px solid rgba(74,44,10,0.12);
    border-bottom: 1px solid rgba(74,44,10,0.12);
  }
  .pj-trust-badges__inner {
    max-width: 124rem;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 2rem 3.2rem;
  }
  .pj-trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
    text-align: center;
    flex: 0 1 160px;
    min-width: 120px;
  }
  .pj-trust-badge__icon {
    width: 5.2rem;
    height: 5.2rem;
    border-radius: 50%;
    background: rgba(200,101,27,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--pj-orange);
  }
  .pj-trust-badge__icon svg {
    width: 2.6rem;
    height: 2.6rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .pj-trust-badge__label {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pj-brown);
    line-height: 1.45;
  }
  @media (max-width: 749px) {
    .pj-trust-badge { flex: 0 1 calc(50% - 1.6rem); }
  }
{%- endstyle -%}

{%- if section.settings.show_section -%}
<div class="pj-trust-badges">
  <div class="pj-trust-badges__inner">

    {%- for block in section.blocks -%}
      <div class="pj-trust-badge" {{ block.shopify_attributes }}>
        <div class="pj-trust-badge__icon">
          {%- case block.settings.icon -%}
            {%- when 'award' -%}
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            {%- when 'leaf' -%}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            {%- when 'star' -%}
              <svg viewBox="0 0 24 24" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- when 'mountain' -%}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
            {%- when 'flame' -%}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
          {%- endcase -%}
        </div>
        <span class="pj-trust-badge__label">{{ block.settings.label | escape }}</span>
      </div>
    {%- endfor -%}

  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "class": "section-trust-badges",
  "disabled_on": { "groups": ["header","footer"] },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "award",    "label": "Award" },
            { "value": "leaf",     "label": "Leaf" },
            { "value": "star",     "label": "Star" },
            { "value": "mountain", "label": "Mountain" },
            { "value": "flame",    "label": "Flame" },
            { "value": "shield",   "label": "Shield" },
            { "value": "check",    "label": "Checkmark" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Trust Badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        { "type": "badge", "settings": { "icon": "award",    "label": "Minority Women Owned Certified" } },
        { "type": "badge", "settings": { "icon": "leaf",     "label": "Handpicked & Shade Grown" } },
        { "type": "badge", "settings": { "icon": "star",     "label": "Kosher Certified" } },
        { "type": "badge", "settings": { "icon": "mountain", "label": "Premium Indian Grown Beans" } },
        { "type": "badge", "settings": { "icon": "flame",    "label": "Freshly Roasted In The USA" } }
      ]
    }
  ]
}
{% endschema %}
