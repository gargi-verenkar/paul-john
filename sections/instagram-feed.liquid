{%- if section.settings.show_section -%}
<div class="pj-instagram">
  {%- if section.settings.heading != blank -%}
    <h2 class="pj-instagram__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <a
    href="{{ section.settings.instagram_url | default: 'https://instagram.com/pauljohncaffeine' }}"
    class="pj-instagram__follow"
    target="_blank"
    rel="noopener noreferrer"
  >
    {{ ig_icon }}
    Follow Us On Instagram
  </a>

  {%- comment -%}
    PLACEHOLDER INSTAGRAM GRID
    6 coffee-themed Unsplash images shown when no blocks are added.
    To replace: add blocks in Theme Customizer → Instagram Feed → Add post → upload image + set URL.
    Or connect a real Instagram feed app (e.g. Instafeed) and remove these placeholder blocks.
  {%- endcomment -%}
  {%- assign placeholder_images = 'https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?w=600&q=80&auto=format&fit=crop,https://images.unsplash.com/photo-1447933601403-0c6688de566e?w=600&q=80&auto=format&fit=crop,https://images.unsplash.com/photo-1611854779393-1b2da9d400fe?w=600&q=80&auto=format&fit=crop,https://images.unsplash.com/photo-1534040385115-33dcb3acba5b?w=600&q=80&auto=format&fit=crop,https://images.unsplash.com/photo-1497935586351-b67a49e012bf?w=600&q=80&auto=format&fit=crop,https://images.unsplash.com/photo-1504630083234-14187a9df0f5?w=600&q=80&auto=format&fit=crop' | split: ',' -%}
  {%- assign placeholder_alts = 'South Indian filter coffee,Roasted coffee beans,Coffee plantation,Coffee flat lay,Green coffee beans,Coffee estate' | split: ',' -%}

  <div class="pj-instagram__grid">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks limit: 6 -%}
        <div class="pj-instagram__post" {{ block.shopify_attributes }}>
          <div class="pj-instagram__post-inner">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  widths: '300,400,600',
                  alt: block.settings.alt | default: 'Instagram post'
              }}
            {%- else -%}
              {%- assign ph_index = forloop.index0 | modulo: 6 -%}
              <img src="{{ placeholder_images[ph_index] }}" alt="{{ placeholder_alts[ph_index] }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;">
            {%- endif -%}
          </div>
          {%- if block.settings.post_url != blank -%}
            <a href="{{ block.settings.post_url }}" class="pj-instagram__overlay" target="_blank" rel="noopener noreferrer" aria-label="View post on Instagram">{{ ig_icon }}</a>
          {%- else -%}
            <a href="{{ section.settings.instagram_url | default: 'https://instagram.com/pauljohncaffeine' }}" class="pj-instagram__overlay" target="_blank" rel="noopener noreferrer" aria-label="View on Instagram">{{ ig_icon }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..6) -%}
        {%- assign ph_index = forloop.index0 -%}
        <div class="pj-instagram__post">
          <div class="pj-instagram__post-inner">
            <img src="{{ placeholder_images[ph_index] }}" alt="{{ placeholder_alts[ph_index] }} — @pauljohncaffeine" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;">
          </div>
          <a href="{{ section.settings.instagram_url | default: 'https://instagram.com/pauljohncaffeine' }}" class="pj-instagram__overlay" target="_blank" rel="noopener noreferrer" aria-label="Follow @pauljohncaffeine on Instagram">{{ ig_icon }}</a>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "class": "section-instagram-feed",
  "disabled_on": { "groups": ["header","footer"] },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LIKE WHAT YOU SEE?"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram profile URL"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Post image"
        },
        {
          "type": "url",
          "id": "post_url",
          "label": "Post link"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "post" }, { "type": "post" }, { "type": "post" },
        { "type": "post" }, { "type": "post" }, { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
