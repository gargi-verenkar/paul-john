{%- style -%}
  .pj-instagram {
    background: var(--pj-cream);
    padding: var(--pj-section-padding-desktop) 2rem;
    text-align: center;
  }
  @media (max-width: 749px) {
    .pj-instagram { padding: var(--pj-section-padding-mobile) 2rem; }
  }
  .pj-instagram__heading {
    font-size: clamp(2rem, 3vw, 3.2rem);
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pj-brown);
    margin: 0 0 1rem;
  }
  .pj-instagram__follow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--pj-orange);
    text-decoration: none;
    margin-bottom: 4rem;
    transition: opacity 0.2s;
  }
  .pj-instagram__follow:hover { opacity: 0.72; }
  .pj-instagram__follow svg { width: 1.8rem; height: 1.8rem; fill: currentColor; }
  .pj-instagram__grid {
    max-width: 124rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (min-width: 750px) { .pj-instagram__grid { gap: 1.4rem; } }
  .pj-instagram__post {
    position: relative;
    overflow: hidden;
    border-radius: 0.4rem;
  }
  .pj-instagram__post::before {
    content: '';
    display: block;
    padding-top: 100%;
  }
  .pj-instagram__post-inner {
    position: absolute;
    inset: 0;
  }
  .pj-instagram__post-inner img,
  .pj-instagram__post-inner .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s;
  }
  .pj-instagram__post:hover .pj-instagram__post-inner img { transform: scale(1.06); }
  .pj-instagram__placeholder {
    position: absolute;
    inset: 0;
    background: rgba(200,101,27,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pj-instagram__placeholder svg {
    width: 36%;
    height: 36%;
    fill: var(--pj-orange);
    opacity: 0.35;
  }
  .pj-instagram__overlay {
    position: absolute;
    inset: 0;
    background: rgba(74,44,10,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .pj-instagram__post:hover .pj-instagram__overlay { opacity: 1; }
  .pj-instagram__overlay svg { width: 3rem; height: 3rem; fill: #fff; }
  .pj-instagram__note {
    margin-top: 2rem;
    font-size: 1.3rem;
    color: rgba(74,44,10,0.5);
    font-style: italic;
  }
{%- endstyle -%}

