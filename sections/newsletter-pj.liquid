{%- style -%}
  #NewsletterPJ-{{ section.id }} {
    --pj-cream:  #FDF6EC;
    --pj-brown:  #4A2C0A;
    --pj-orange: #C8651B;
    background: var(--pj-brown);
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    text-align: center;
  }
  @media screen and (max-width: 749px) {
    #NewsletterPJ-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round }}px;
    }
  }
  #NewsletterPJ-{{ section.id }} .nl__inner {
    max-width: 72rem;
    margin: 0 auto;
  }
  #NewsletterPJ-{{ section.id }} .nl__heading {
    font-size: clamp(2.8rem, 5vw, 4.8rem);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pj-cream);
    margin: 0 0 1.6rem;
  }
  #NewsletterPJ-{{ section.id }} .nl__subtext {
    font-size: 1.6rem;
    color: rgba(253,246,236,0.75);
    margin: 0 0 3.6rem;
  }
  #NewsletterPJ-{{ section.id }} .nl__form {
    display: flex;
    gap: 0;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.2rem;
  }
  #NewsletterPJ-{{ section.id }} .nl__input {
    flex: 1 1 28rem;
    max-width: 42rem;
    padding: 1.4rem 2rem;
    background: rgba(253,246,236,0.1);
    border: 2px solid rgba(253,246,236,0.4);
    border-radius: 0.3rem;
    color: var(--pj-cream);
    font-size: 1.5rem;
    outline: none;
    transition: border-color 0.2s;
  }
  #NewsletterPJ-{{ section.id }} .nl__input::placeholder {
    color: rgba(253,246,236,0.5);
  }
  #NewsletterPJ-{{ section.id }} .nl__input:focus {
    border-color: var(--pj-orange);
  }
  #NewsletterPJ-{{ section.id }} .nl__btn {
    padding: 1.4rem 3.2rem;
    background: var(--pj-orange);
    color: var(--pj-cream);
    border: 2px solid var(--pj-orange);
    border-radius: 0.3rem;
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.25s, color 0.25s;
    flex: 0 0 auto;
  }
  #NewsletterPJ-{{ section.id }} .nl__btn:hover {
    background: transparent;
    color: var(--pj-orange);
  }
  #NewsletterPJ-{{ section.id }} .nl__success {
    font-size: 1.6rem;
    color: #a8e6a3;
    margin-top: 2rem;
    font-weight: 600;
  }
  #NewsletterPJ-{{ section.id }} .nl__error {
    font-size: 1.4rem;
    color: #f9a8a8;
    margin-top: 1.2rem;
  }
{%- endstyle -%}

<div id="NewsletterPJ-{{ section.id }}">
  <div class="nl__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="nl__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="nl__subtext">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'NewsletterPJForm-{{ section.id }}', class: 'nl__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        class="nl__input"
        value="{{ form.email }}"
        placeholder="Enter your email address"
        aria-label="Email address"
        autocomplete="email"
        required
        {%- if form.errors %}aria-invalid="true"{%- endif -%}
      >
      <button type="submit" class="nl__btn" name="commit">
        {{ section.settings.button_label | default: 'SUBMIT' | escape }}
      </button>
    {%- endform -%}

{% form 'customer' %}
    {%- if form.posted_successfully? -%}
      <p class="nl__success">Thanks for subscribing! We'll be in touch soon.</p>
    {%- endif -%}
    {%- if form.errors -%}
      <p class="nl__error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
    {%- endif -%}
    <input type="email" name="contact[email]">
{% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Newsletter (PJ)",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEVER MISS OUT!"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Stay up to date with our latest products!"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SUBMIT"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Newsletter (PJ)"
    }
  ]
}
{% endschema %}
