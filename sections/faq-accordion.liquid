{%- style -%}
  .pj-faq {
    background: #fff;
    padding: var(--pj-section-padding-desktop) 2rem;
  }
  @media (max-width: 749px) {
    .pj-faq { padding: var(--pj-section-padding-mobile) 2rem; }
  }
  .pj-faq__heading {
    text-align: center;
    font-size: clamp(2.2rem, 3vw, 3.4rem);
    font-weight: 700;
    color: var(--pj-brown);
    margin: 0 0 4.8rem;
    letter-spacing: 0.06em;
  }
  .pj-faq__list {
    max-width: 80rem;
    margin: 0 auto;
    list-style: none;
    padding: 0;
  }
  .pj-faq__item {
    border-bottom: 1px solid rgba(74,44,10,0.15);
  }
  .pj-faq__item:first-child { border-top: 1px solid rgba(74,44,10,0.15); }
  .pj-faq__btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.2rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: var(--pj-brown);
    font-size: 1.7rem;
    font-weight: 600;
    line-height: 1.4;
    transition: color 0.2s;
    font-family: var(--pj-font);
  }
  .pj-faq__btn:hover,
  .pj-faq__item[data-open] .pj-faq__btn { color: var(--pj-orange); }
  .pj-faq__icon {
    flex-shrink: 0;
    width: 2.4rem;
    height: 2.4rem;
    border: 2px solid currentColor;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pj-faq__icon svg {
    width: 1.2rem; height: 1.2rem;
    fill: none; stroke: currentColor;
    stroke-width: 2.5; stroke-linecap: round;
  }
  .pj-faq__icon .minus { display: none; }
  .pj-faq__item[data-open] .pj-faq__icon .plus  { display: none; }
  .pj-faq__item[data-open] .pj-faq__icon .minus { display: block; }
  .pj-faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }
  .pj-faq__answer-inner {
    padding: 0 0 2.6rem;
    font-size: 1.5rem;
    line-height: 1.8;
    color: rgba(74,44,10,0.72);
  }
  .pj-faq__answer-inner p { margin: 0; }
{%- endstyle -%}

<div class="pj-faq">
  {%- if section.settings.heading != blank -%}
    <h2 class="pj-faq__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <ul class="pj-faq__list" id="pjFaq-{{ section.id }}">
    {%- for block in section.blocks -%}
      <li class="pj-faq__item" {{ block.shopify_attributes }}>
        <button
          type="button"
          class="pj-faq__btn"
          aria-expanded="false"
          aria-controls="pjFaqA-{{ section.id }}-{{ forloop.index }}"
        >
          <span>{{ block.settings.question | escape }}</span>
          <span class="pj-faq__icon" aria-hidden="true">
            <svg class="plus"  viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <svg class="minus" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </span>
        </button>
        <div
          class="pj-faq__answer"
          id="pjFaqA-{{ section.id }}-{{ forloop.index }}"
        >
          <div class="pj-faq__answer-inner">{{ block.settings.answer }}</div>
        </div>
      </li>
    {%- endfor -%}
  </ul>
</div>

<script>
(function(){
  var list = document.getElementById('pjFaq-{{ section.id }}');
  if (!list) return;
  list.querySelectorAll('.pj-faq__btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var item   = btn.closest('.pj-faq__item');
      var panel  = item.querySelector('.pj-faq__answer');
      var isOpen = item.hasAttribute('data-open');
      list.querySelectorAll('.pj-faq__item[data-open]').forEach(function(o){
        o.removeAttribute('data-open');
        o.querySelector('.pj-faq__answer').style.maxHeight = '0';
        o.querySelector('.pj-faq__btn').setAttribute('aria-expanded','false');
      });
      if (!isOpen){
        item.setAttribute('data-open','');
        panel.style.maxHeight = panel.scrollHeight + 'px';
        btn.setAttribute('aria-expanded','true');
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "tag": "section",
  "class": "section-faq-accordion",
  "disabled_on": { "groups": ["header","footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "F.A.Q."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Where Do Arabica Coffee Beans Come From?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Arabica coffee beans originate from Ethiopia back in the 15th century. They were first discovered in the Kaffa region, where they were found growing abundantly in the wild.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Where Do Arabica Coffee Beans Come From?",
            "answer": "<p>Arabica coffee beans originate from Ethiopia back in the 15th century. They were first discovered in the Kaffa region, where they were found growing abundantly in the wild.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What Are Single-Origin Coffee Beans?",
            "answer": "<p>Coffee beans that come from a specific region, farm, or producer within a single country are called single-origin coffee beans.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Why Does Indian Coffee Taste Different?",
            "answer": "<p>Traditional South Indian coffee is made with a blend of Arabica and Robusta beans, often combined with chicory to enrich the flavor and body of the brew.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
