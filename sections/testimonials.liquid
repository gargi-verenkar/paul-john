{%- style -%}
  .pj-testimonials {
    background: var(--pj-cream);
    padding: var(--pj-section-padding-desktop) 2rem;
  }
  @media (max-width: 749px) {
    .pj-testimonials { padding: var(--pj-section-padding-mobile) 2rem; }
  }
  .pj-testimonials__header {
    text-align: center;
    margin-bottom: 5rem;
  }
  .pj-testimonials__label {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--pj-orange);
    display: block;
    margin-bottom: 0.8rem;
  }
  .pj-testimonials__heading {
    font-size: clamp(2rem, 3vw, 3.2rem);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pj-brown);
    margin: 0 0 0.8rem;
  }
  .pj-testimonials__subheading {
    font-size: 1.6rem;
    font-style: italic;
    color: rgba(74,44,10,0.65);
    margin: 0;
  }
  .pj-testimonials__grid {
    max-width: 124rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 750px) { .pj-testimonials__grid { grid-template-columns: repeat(2,1fr); } }
  @media (min-width: 990px) { .pj-testimonials__grid { grid-template-columns: repeat(3,1fr); } }
  .pj-tcard {
    background: #fff;
    border: 1px solid rgba(74,44,10,0.1);
    border-radius: 0.6rem;
    padding: 3.2rem 2.8rem 2.8rem;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .pj-tcard__quote-mark {
    font-family: Georgia, serif;
    font-size: 6rem;
    line-height: 0.7;
    color: var(--pj-orange);
    opacity: 0.3;
    user-select: none;
  }
  .pj-tcard__quote {
    font-size: 1.45rem;
    font-style: italic;
    color: rgba(74,44,10,0.8);
    line-height: 1.75;
    flex: 1;
    margin: 0;
  }
  .pj-tcard__quote p { margin: 0; }
  .pj-tcard__divider { height: 1px; background: rgba(74,44,10,0.1); }
  .pj-tcard__reviewer-name {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--pj-brown);
    margin: 0 0 0.3rem;
  }
  .pj-tcard__reviewer-title {
    font-size: 1.2rem;
    color: rgba(74,44,10,0.5);
    margin: 0;
  }
  .pj-tcard__footer {
    display: flex; align-items: center; gap: 1.2rem;
  }
  .pj-tcard__avatar {
    width: 4.4rem; height: 4.4rem; border-radius: 50%;
    overflow: hidden; flex-shrink: 0;
    border: 2px solid rgba(200,101,27,0.25);
  }
  .pj-tcard__avatar img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .pj-tcard__stars {
    color: var(--pj-orange);
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    line-height: 1;
  }
{%- endstyle -%}

<div class="pj-testimonials">
  <div class="pj-testimonials__header">
    <span class="pj-testimonials__label">Testimonials</span>
    {%- if section.settings.heading != blank -%}
      <h2 class="pj-testimonials__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="pj-testimonials__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
  </div>

  {%- comment -%}
    Placeholder avatars — replace by adding image_picker field to schema,
    or swap Unsplash URLs here once real reviewer photos are provided.
  {%- endcomment -%}
  {%- assign avatar_urls = 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&q=80&auto=format&fit=crop&crop=faces,https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=120&q=80&auto=format&fit=crop&crop=faces,https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=120&q=80&auto=format&fit=crop&crop=faces' | split: ',' -%}

  <div class="pj-testimonials__grid">
    {%- for block in section.blocks -%}
      <div class="pj-tcard" {{ block.shopify_attributes }}>
        <div class="pj-tcard__stars">★★★★★</div>
        <div class="pj-tcard__quote-mark" aria-hidden="true">&ldquo;</div>
        {%- if block.settings.quote != blank -%}
          <div class="pj-tcard__quote">{{ block.settings.quote }}</div>
        {%- endif -%}
        <div class="pj-tcard__divider"></div>
        {%- if block.settings.name != blank -%}
          <div class="pj-tcard__footer">
            <div class="pj-tcard__avatar">
              {%- assign avatar_index = forloop.index0 | modulo: 3 -%}
              <img src="{{ avatar_urls[avatar_index] }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            </div>
            <div>
              <p class="pj-tcard__reviewer-name">{{ block.settings.name | escape }}</p>
              {%- if block.settings.title != blank -%}
                <p class="pj-tcard__reviewer-title">{{ block.settings.title | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "disabled_on": { "groups": ["header","footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TESTIMONIALS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "What our beloved customers have to say about us"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Reviewer title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>I had the privilege of traveling with Mr. Paul John... ethically procured from plantations around Coorg. The flavour is unmatched.</p>",
            "name": "Koray Kaan Özdemir",
            "title": "World Whisky Brand Ambassador of the Year 2023"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>Smell of Rain is an extraordinary pour. Full, rich, bold, balanced, hints of cocoa, sweet and tangy.</p>",
            "name": "Steve Beal",
            "title": "Verified Purchase"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>Excellent. Ground the beans to a coarse grind and used a French press to brew the coffee. The flavour was outstanding.</p>",
            "name": "Renate Stensland",
            "title": "Verified Purchase"
          }
        }
      ]
    }
  ]
}
{% endschema %}
