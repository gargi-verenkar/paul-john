{%- style -%}
  #FooterPJ-{{ section.id }} {
    --pj-cream:  #FDF6EC;
    --pj-brown:  #4A2C0A;
    --pj-brown-dark: #2A1505;
    --pj-orange: #C8651B;
  }
  #FooterPJ-{{ section.id }} .fpj__main {
    background: var(--pj-brown);
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    #FooterPJ-{{ section.id }} .fpj__main {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round }}px;
    }
  }
  #FooterPJ-{{ section.id }} .fpj__grid {
    max-width: 128rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media screen and (min-width: 750px) {
    #FooterPJ-{{ section.id }} .fpj__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (min-width: 990px) {
    #FooterPJ-{{ section.id }} .fpj__grid {
      grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
      gap: 6rem;
    }
  }
  /* Brand col */
  #FooterPJ-{{ section.id }} .fpj__brand-name {
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pj-cream);
    margin: 0 0 0.8rem;
    line-height: 1.1;
  }
  #FooterPJ-{{ section.id }} .fpj__brand-tagline {
    font-size: 1.3rem;
    color: rgba(253,246,236,0.65);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 2rem;
  }
  /* Column headings */
  #FooterPJ-{{ section.id }} .fpj__col-heading {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pj-orange);
    margin: 0 0 1.8rem;
  }
  /* Nav links */
  #FooterPJ-{{ section.id }} .fpj__nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  #FooterPJ-{{ section.id }} .fpj__nav a {
    font-size: 1.45rem;
    color: rgba(253,246,236,0.8);
    text-decoration: none;
    transition: color 0.2s;
    line-height: 1.4;
  }
  #FooterPJ-{{ section.id }} .fpj__nav a:hover {
    color: var(--pj-orange);
  }
  /* Contact items */
  #FooterPJ-{{ section.id }} .fpj__contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  #FooterPJ-{{ section.id }} .fpj__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    color: rgba(253,246,236,0.8);
    font-size: 1.4rem;
    line-height: 1.5;
  }
  #FooterPJ-{{ section.id }} .fpj__contact-item svg {
    width: 1.7rem;
    height: 1.7rem;
    flex-shrink: 0;
    fill: none;
    stroke: var(--pj-orange);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    margin-top: 0.2rem;
  }
  #FooterPJ-{{ section.id }} .fpj__contact-item a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  #FooterPJ-{{ section.id }} .fpj__contact-item a:hover {
    color: var(--pj-orange);
  }
  #FooterPJ-{{ section.id }} .fpj__affiliate-link {
    display: inline-block;
    margin-top: 1.8rem;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pj-orange);
    text-decoration: none;
    border-bottom: 1px solid var(--pj-orange);
    padding-bottom: 0.2rem;
    transition: opacity 0.2s;
  }
  #FooterPJ-{{ section.id }} .fpj__affiliate-link:hover { opacity: 0.7; }

  /* Divider */
  #FooterPJ-{{ section.id }} .fpj__divider {
    border: none;
    border-top: 1px solid rgba(253,246,236,0.12);
    max-width: 128rem;
    margin: 4rem auto 0;
  }
  /* Social */
  #FooterPJ-{{ section.id }} .fpj__social {
    background: var(--pj-brown);
    padding: 2.8rem 2rem;
    text-align: center;
  }
  #FooterPJ-{{ section.id }} .fpj__social-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: 2.4rem;
  }
  #FooterPJ-{{ section.id }} .fpj__social-list a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    border: 1px solid rgba(253,246,236,0.25);
    color: rgba(253,246,236,0.75);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  #FooterPJ-{{ section.id }} .fpj__social-list a:hover {
    color: var(--pj-cream);
    border-color: var(--pj-orange);
    background: var(--pj-orange);
  }
  #FooterPJ-{{ section.id }} .fpj__social-list svg {
    width: 1.8rem;
    height: 1.8rem;
    fill: currentColor;
  }
  /* Payment */
  #FooterPJ-{{ section.id }} .fpj__payment {
    background: var(--pj-brown);
    padding: 1.6rem 2rem 2.4rem;
    text-align: center;
    border-top: 1px solid rgba(253,246,236,0.08);
  }
  #FooterPJ-{{ section.id }} .fpj__payment-inner {
    max-width: 128rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    flex-wrap: wrap;
  }
  #FooterPJ-{{ section.id }} .fpj__payment-label {
    font-size: 1.2rem;
    color: rgba(253,246,236,0.5);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  #FooterPJ-{{ section.id }} .fpj__payment .icon--full-color {
    height: 2.4rem;
    width: auto;
  }
  /* Copyright */
  #FooterPJ-{{ section.id }} .fpj__copyright {
    background: var(--pj-brown-dark);
    padding: 1.6rem 2rem;
    text-align: center;
  }
  #FooterPJ-{{ section.id }} .fpj__copyright p {
    margin: 0;
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(253,246,236,0.5);
  }
{%- endstyle -%}

<div id="FooterPJ-{{ section.id }}">
  <!-- Main footer grid -->
  <div class="fpj__main">
    <div class="fpj__grid">

      <!-- Brand column -->
      <div class="fpj__col">
        <p class="fpj__brand-name">{{ section.settings.logo_text | default: shop.name }}</p>
        {%- if section.settings.tagline != blank -%}
          <p class="fpj__brand-tagline">{{ section.settings.tagline | escape }}</p>
        {%- endif -%}
      </div>

      <!-- Link list columns -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="fpj__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="fpj__col-heading">{{ block.settings.heading | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="fpj__nav">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- Connect / Contact column -->
      <div class="fpj__col">
        <h3 class="fpj__col-heading">Connect With Us</h3>
        <ul class="fpj__contact-list">
          {%- if section.settings.phone != blank -%}
            <li class="fpj__contact-item">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.99 5.99l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone | escape }}</a>
            </li>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <li class="fpj__contact-item">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a>
            </li>
          {%- endif -%}
          {%- if section.settings.address != blank -%}
            <li class="fpj__contact-item">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>{{ section.settings.address }}</div>
            </li>
          {%- endif -%}
        </ul>
        {%- if section.settings.affiliate_link != blank -%}
          <a href="{{ section.settings.affiliate_link }}" class="fpj__affiliate-link" target="_blank" rel="noopener">
            {{ section.settings.affiliate_label | default: 'Become an Affiliate' | escape }}
          </a>
        {%- endif -%}
      </div>

    </div>
    <hr class="fpj__divider">
  </div>

  <!-- Social icons row -->
  {%- liquid
    assign has_social = false
    if settings.social_instagram_link != blank or settings.social_facebook_link != blank or settings.social_twitter_link != blank or settings.social_youtube_link != blank or settings.social_pinterest_link != blank
      assign has_social = true
    endif
  -%}
  {%- if has_social -%}
    <div class="fpj__social">
      <ul class="fpj__social-list" aria-label="Social media links">
        {%- if settings.social_instagram_link != blank -%}
          <li><a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a></li>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <li><a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a></li>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <li><a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X">
            <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a></li>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <li><a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <svg viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20.06 12 20.06 12 20.06s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="var(--pj-brown)"/></svg>
          </a></li>
        {%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}
          <li><a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a></li>
        {%- endif -%}
      </ul>
    </div>
  {%- endif -%}

  <!-- Payment icons -->
  {%- if shop.enabled_payment_types.size > 0 -%}
    <div class="fpj__payment">
      <div class="fpj__payment-inner">
        <span class="fpj__payment-label">We Accept</span>
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <!-- Copyright bar -->
  <div class="fpj__copyright">
    <p>{{ section.settings.logo_text | default: shop.name | upcase }} &copy; {{ 'now' | date: '%Y' }} ALL RIGHTS RESERVED</p>
  </div>
</div>

{% schema %}
{
  "name": "Footer (PJ)",
  "tag": "section",
  "class": "section-footer-pj",
  "enabled_on": { "groups": ["footer"] },
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Brand name",
      "default": "Paul John Caffeine"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Premium South Indian Coffee"
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address"
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "Address"
    },
    {
      "type": "url",
      "id": "affiliate_link",
      "label": "Affiliate program link"
    },
    {
      "type": "text",
      "id": "affiliate_label",
      "label": "Affiliate link text",
      "default": "Become an Affiliate"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer (PJ)",
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "heading": "Links",
            "menu": "footer"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Coffee Varieties"
          }
        }
      ]
    }
  ]
}
{% endschema %}
